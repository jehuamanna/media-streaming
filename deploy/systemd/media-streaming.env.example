# Copy to /etc/media-streaming.env and chmod 600.
# Required: JWT_SECRET (min 16 chars).
# ADMIN_INITIAL_PASSWORD: only needed until an admin user exists in the DB (min 8 chars).

JWT_SECRET=replace-with-a-long-random-secret-at-least-16-chars
ADMIN_INITIAL_PASSWORD=replace-with-strong-temp-password-min-8

# Optional overrides (defaults match Jenkinsfile / README):
# CONTAINER_NAME=media-streaming
# IMAGE=media-streaming:latest
# VIDEOS_PATH=/streaming/Videos
# DATA_VOLUME=media-streaming-data
# HTTP_PORT=8020
# RTMP_PORT=1935
# Sidecar HLS (library must be writable in the container):
#   VOD_HLS_LAYOUT=sidecar
#   VIDEOS_MOUNT_SUFFIX=
